# RocketMQ Studio Docker Environment
# Copy to deploy/.env and replace every placeholder before remote deployment.
REMOTE_HOST=studio.example.com
REMOTE_USER=deploy-user
REMOTE_PATH=/opt/rocketmq-studio

# Required for "server" and "all": exact local path to a mode-0600 registry.
STUDIO_SECURITY_USER_FILE_LOCAL=/absolute/path/to/studio-users.json

# Remote loopback listener and private Podman network.
PUBLIC_PORT=6789
PODMAN_NETWORK=rocketmq-studio
